# ── Application ──────────────────────────────────────────────────────
APP_NAME=Social Support AI
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# ── API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:8501,http://localhost:8000

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-secure-random-key-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=social_support
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── MongoDB ──────────────────────────────────────────────────────────
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=social_support
MONGODB_USER=app_user
MONGODB_PASSWORD=app_password

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PREFER_GRPC=false

# ── Neo4j ────────────────────────────────────────────────────────────
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=app_password
NEO4J_DATABASE=neo4j

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Ollama ───────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=mistral:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=qwen2.5-vl:7b
OLLAMA_TIMEOUT=120

# ── Langfuse ─────────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── ML ───────────────────────────────────────────────────────────────
ML_MODEL_PATH=data/models/eligibility_rf.pkl
ML_FEATURE_CONFIG_PATH=configs/features.yaml
ML_CONFIDENCE_THRESHOLD=0.7
ML_AUTO_APPROVE_THRESHOLD=0.85
ML_AUTO_DECLINE_THRESHOLD=0.3

# ── Workflow ─────────────────────────────────────────────────────────
WORKFLOW_MAX_RETRIES=3
WORKFLOW_OCR_CONFIDENCE_MIN=0.6
WORKFLOW_HITL_INCONSISTENCY_THRESHOLD=3
